# Runtime
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501

# Database / Redis
# Local Docker Postgres:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tfn
# Supabase transaction-mode pooler example:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=replace-with-a-strong-32-byte-secret
JWT_SECRET=replace-with-a-strong-jwt-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
COOKIE_DOMAIN=
COOKIE_SECURE=false

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=TFN <notifications@example.com>

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# AI / Matching
OPENAI_API_KEY=
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_REQUEST_TIMEOUT_MS=60000
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_CHAT_MODEL=qwen-plus
QWEN_REQUEST_TIMEOUT_MS=30000
CHROMA_URL=http://localhost:8000
CHROMA_PROFILE_COLLECTION=tfn_freelancer_profiles
CHROMA_PROJECT_COLLECTION=tfn_project_requirements
CHROMA_GLOBAL_COLLECTION=tfn_global_search
EMBEDDING_DEBOUNCE_MS=300000
MATCH_EXPLANATION_TTL_SECONDS=86400
MATCH_FEED_CACHE_TTL_SECONDS=120
