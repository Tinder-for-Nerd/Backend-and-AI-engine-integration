# App
APP_NAME=Auth-Security
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Database (SQLite for local testing)
DATABASE_URL=sqlite+aiosqlite:///./auth.db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookies
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Rate limiting
API_RATE_LIMIT=100
AUTH_RATE_LIMIT=5
RATE_LIMIT_WINDOW_SECONDS=60

# Brute-force lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Google OAuth — place client_secret_*.json in project root OR set IDs manually
GOOGLE_CREDENTIALS_FILE=client_secret_89091882189-et5osrtklqlhjoo9un2du88qvpntlj03.apps.googleusercontent.com.json
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# LinkedIn OAuth (https://www.linkedin.com/developers/)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/linkedin/callback

# Frontend redirect after OAuth
OAUTH_SUCCESS_REDIRECT=http://localhost:8000/
